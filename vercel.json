{
  "outputDirectory": "dist",
  "buildCommand": "npm run build:web",
  "installCommand": "npm install --legacy-peer-deps && chmod +x node_modules/.bin/expo",
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/(.*)", "destination": "/admin/index.html" }
  ]
}