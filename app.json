{
  "expo": {
    "name": "SplitSaathi",
    "slug": "splitsaathi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "splitsaathi",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#003527"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.splitsaathi.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSContactsUsageDescription": "Apne contacts mein se friends dhundhne ke liye.",
        "NSCameraUsageDescription": "Bill receipts scan karne ke liye.",
        "NSPhotoLibraryUsageDescription": "Bill receipts upload karne ke liye.",
        "NSUserNotificationUsageDescription": "Bill reminders aur payment alerts ke liye.",
        "NSFaceIDUsageDescription": "Secure login ke liye biometric use karna.",
        "NSLocationWhenInUseUsageDescription": "Nearby trip suggestions dikhane ke liye.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "splitsaathi"
            ]
          }
        ]
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.splitsaathi.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "splitsaathi.app",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "splitsaathi"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-contacts",
        {
          "contactsPermission": "Contacts se friends dhundne ke liye permission chahiye."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#10b981"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Bill receipts upload karne ke liye.",
          "cameraPermission": "Bill receipts scan karne ke liye."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Nearby trip suggestions dikhane ke liye."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "supabaseUrl": "https://bmhgnbvaufeafhennvaj.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJtaGduYnZhdWZlYWZoZW5udmFqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE5NzI4MTcsImV4cCI6MjA5NzU0ODgxN30.ZQXBEI23RMG5qIJAmGdKvcgPciPj2Jlpyd3XqSRSRpc",
      "razorpayKeyId": "YOUR_RAZORPAY_KEY_ID"
    },
    "owner": "splitsaathi",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/your-project-id",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
  }
}